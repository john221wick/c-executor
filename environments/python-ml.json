{
  "name": "python-ml",
  "rootfs": "../../test/rootfs/python-ml",
  "compile": null,
  "run": ["/test/venvs/python-ml/bin/python", "{source}"],
  "extension": ".py",
  "limits": {
    "memory_mb": 2048,
    "cpu_time_ms": 30000,
    "wall_time_ms": 60000,
    "max_pids": 32
  },
  "read_only_mounts": [
    {
      "source": "../../test/venvs/python-ml",
      "target": "/test/venvs/python-ml"
    }
  ],
  "network": false,
  "gpu": true
}
